{
  "name": "airdrop-odoo-crm",
  "version": "0.0.1",
  "description": "DevRev AirSync connector for Odoo CRM (accounts, contacts, opportunities)",
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "build:watch": "tsc --watch",
    "prepackage": "npm run build",
    "package": "tar -cvzf build.tar.gz dist package.json package-lock.json",
    "start": "ts-node ./src/main.ts",
    "start:watch": "nodemon ./src/main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@devrev/ts-adaas": "^1.12.0",
    "@devrev/typescript-sdk": "^1.0.0",
    "axios": "^1.12.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.1.0",
    "rimraf": "^6.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "@babel/core": "^7.27.0",
    "@babel/preset-env": "^7.27.0",
    "@babel/preset-typescript": "^7.27.0",
    "babel-jest": "^29.7.0",
    "yargs": "^17.7.0",
    "dotenv": "^16.4.0"
  }
}
